{
  "name": "astrbot-live2d-desktop",
  "version": "1.3.1",
  "description": "AstrBot Live2D 桌面应用",
  "main": "dist-electron/main.js",
  "type": "module",
  "author": "lxfight <1686540385@qq.com>",
  "license": "MIT",
  "keywords": [
    "electron",
    "vue3",
    "live2d",
    "astrbot"
  ],
  "cubism": {
    "sdkBaseline": "5-r.4",
    "frameworkRepo": "https://github.com/Live2D/CubismWebFramework.git",
    "frameworkTag": "5-r.4",
    "frameworkCommit": "8df84780f2aa1298f3b30965cdae143e049f3c8e",
    "samplesRepo": "https://github.com/Live2D/CubismWebSamples.git",
    "samplesTag": "5-r.4",
    "samplesCommit": "435707a4676c19de754a8a557638450f889dcd2c",
    "core": {
      "filename": "live2dcubismcore.min.js",
      "downloadUrl": "https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js",
      "runtimeSource": "official-sdk-download",
      "expectedHash": "sha256-25ae938cb4fe282ce189b357bcc97e603d1e1f7ec78bf04150d401c23cdc792f"
    }
  },
  "desktopMetadata": {
    "protocol": {
      "version": "1.0.0"
    },
    "links": {
      "astrbot": "https://github.com/AstrBotDevs/AstrBot",
      "repository": "https://github.com/lxfight/astrbot-live2d-desktop",
      "adapterPlugin": "https://github.com/lxfight/astrbot_plugin_live2d_adapter"
    },
    "storage": {
      "local": {
        "advancedSettings": {
          "key": "advancedSettings",
          "version": 1
        },
        "connectionSettings": {
          "key": "connectionSettings",
          "version": 2
        },
        "modelPositions": {
          "key": "modelPositions",
          "version": 1
        },
        "modelScales": {
          "key": "modelScales",
          "version": 1
        },
        "themeState": {
          "key": "rendererThemeState",
          "version": 1
        },
        "lastModelPath": {
          "key": "lastModelPath"
        }
      },
      "userConfig": {
        "userId": "user_id",
        "userName": "user_name",
        "autoUpdateEnabled": "app_auto_update_enabled",
        "screenshotDefaultTarget": "desktop_capture_default_target",
        "screenshotQuality": "desktop_capture_quality",
        "screenshotMaxWidth": "desktop_capture_max_width",
        "connectionSettingsV3": "connection_settings_v3",
        "connectionBehaviorSettingsV1": "connection_behavior_settings_v1",
        "alwaysOnTop": "tray_always_on_top",
        "fullPassThrough": "tray_pass_through_mode",
        "dynamicPassThrough": "desktop_dynamic_pass_through",
        "autoDetectFullscreen": "tray_game_mode"
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write \"**/*.{ts,tsx,vue,js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,vue,js,jsx,json,css,scss,md}\"",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs');['release','dist','dist-electron'].forEach(p=>fs.existsSync(p)&&fs.rmSync(p,{recursive:true,force:true}));\"",
    "rebuild": "node scripts/rebuild-native.js",
    "rebuild:optional": "node scripts/rebuild-native.js --optional",
    "cubism:patch": "node scripts/apply-cubism-framework-patches.mjs",
    "postinstall": "concurrently -n rebuild,core,framework \"node scripts/rebuild-native.js --optional\" \"node scripts/download-cubism-core.js\" \"node scripts/download-framework.js\" && node scripts/apply-cubism-framework-patches.mjs",
    "setup:framework": "node scripts/download-framework.js",
    "setup:framework:force": "node scripts/download-framework.js --force",
    "icons:generate": "node scripts/generate-icons.mjs",
    "rebuild:electron": "electron-rebuild -f -w extract-file-icon,node-window-manager,better-sqlite3",
    "build:prepare": "pnpm run typecheck && pnpm exec vite build",
    "build:vite": "pnpm exec vite build",
    "pack": "pnpm exec electron-builder --publish never && node scripts/generate-portable-update-metadata.mjs",
    "pack:dir": "pnpm exec electron-builder --dir --publish never",
    "pack:win": "pnpm exec electron-builder --win --publish never && node scripts/generate-portable-update-metadata.mjs",
    "pack:mac": "pnpm exec electron-builder --mac --publish never",
    "pack:linux": "pnpm exec electron-builder --linux --publish never",
    "pack:linux:core": "pnpm exec electron-builder --linux AppImage deb --publish never",
    "pack:linux:pacman": "pnpm exec electron-builder --linux pacman --publish never",
    "pack:linux:snap": "pnpm exec electron-builder --linux snap --publish never",
    "pack:linux:arm64": "pnpm exec electron-builder --linux AppImage deb --arm64 --publish never",
    "build": "pnpm run clean && pnpm run build:prepare && pnpm run rebuild:optional && pnpm run pack",
    "build:dir": "pnpm run clean && pnpm run build:prepare && pnpm run rebuild:optional && pnpm run pack:dir",
    "build:dir:fast": "pnpm run clean && pnpm run build:vite && pnpm run rebuild:optional && pnpm run pack:dir",
    "build:win": "pnpm run clean && pnpm run build:prepare && pnpm run rebuild:optional && pnpm run pack:win",
    "build:mac": "pnpm run clean && pnpm run build:prepare && pnpm run rebuild:optional && pnpm run pack:mac",
    "build:linux": "pnpm run clean && pnpm run build:prepare && pnpm run rebuild:optional && pnpm run pack:linux",
    "build:fast": "pnpm run clean && pnpm run build:vite && pnpm run pack:dir",
    "build:ci:win": "pnpm run clean && pnpm run build:prepare && pnpm run pack:win",
    "build:ci:mac": "pnpm run clean && pnpm run build:prepare && pnpm run pack:mac",
    "build:ci:linux": "pnpm run clean && pnpm run build:prepare && pnpm run pack:linux",
    "build:ci:linux:core": "pnpm run clean && pnpm run build:prepare && pnpm run pack:linux:core",
    "build:ci:linux:pacman": "pnpm run clean && pnpm run build:prepare && pnpm run pack:linux:pacman",
    "build:ci:linux:snap": "pnpm run clean && pnpm run build:prepare && pnpm run pack:linux:snap",
    "build:ci:linux:arm64": "pnpm run clean && pnpm run build:prepare && pnpm run pack:linux:arm64",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix --max-warnings=-1",
      "prettier --write"
    ],
    "*.{js,jsx,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.37",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/language-core": "^3.2.6",
    "concurrently": "^8.2.2",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "node-gyp-build": "^4.8.4",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.99.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.4.1",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "active-win": "^9.0.0",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "bufferutil": "^4.1.0",
    "colorthief": "^2.7.0",
    "date-fns": "^3.6.0",
    "dompurify": "^3.3.3",
    "echarts": "^5.6.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "extract-file-icon": "^0.3.2",
    "howler": "^2.2.4",
    "katex": "^0.16.44",
    "koffi": "^2.15.2",
    "lucide-vue-next": "^0.563.0",
    "marked": "^17.0.5",
    "naive-ui": "^2.44.1",
    "node-addon-api": "^8.7.0",
    "pinia": "^3.0.4",
    "simplex-noise": "^4.0.3",
    "utf-8-validate": "^6.0.6",
    "uuid": "^9.0.1",
    "vue": "^3.5.31",
    "vue-i18n": "^10.0.8",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "node-window-manager": "^2.2.4"
  },
  "build": {
    "appId": "com.astrbot.live2d.desktop",
    "productName": "AstrBot Live2D Desktop",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "extraResources": [
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      },
      {
        "from": "resources/icon.icns",
        "to": "icon.icns"
      }
    ],
    "asar": true,
    "npmRebuild": false,
    "files": [
      "dist/**",
      "dist-electron/**",
      "node_modules/active-win/package.json",
      "node_modules/active-win/index.js",
      "node_modules/active-win/index.d.ts",
      "node_modules/active-win/lib/**",
      "node_modules/better-sqlite3/package.json",
      "node_modules/better-sqlite3/lib/**",
      "node_modules/better-sqlite3/build/Release/*.node",
      "node_modules/node-window-manager/package.json",
      "node_modules/node-window-manager/dist/**",
      "node_modules/node-window-manager/build/Release/*.node",
      "node_modules/extract-file-icon/package.json",
      "node_modules/extract-file-icon/dist/**",
      "node_modules/extract-file-icon/build/Release/*.node",
      "node_modules/node-gyp-build/**",
      "node_modules/node-addon-api/**",
      "package.json",
      "!dist/models/**/.git/**",
      "!dist/models/**/.svn/**",
      "!dist/models/**/node_modules/**",
      "!dist/models/**/{test,tests,__tests__,example,examples}/**",
      "!dist/models/package.json/**",
      "!dist/models/temp/**",
      "!dist/wakeword/**",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/*.vue",
      "!**/*.md",
      "!**/*.log",
      "!**/node_modules/*/{test,tests,__tests__,docs,doc,example,examples}/**",
      "!**/node_modules/.cache/**"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "artifactName": "astrbot-live2d-desktop-v${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "lxfight",
        "repo": "astrbot-live2d-desktop"
      }
    ],
    "compression": "maximum",
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "astrbot-live2d-desktop-v${version}-win-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "runAfterFinish": true,
      "packElevateHelper": true
    },
    "portable": {
      "artifactName": "astrbot-live2d-desktop-v${version}-portable-${arch}.${ext}"
    },
    "mac": {
      "icon": "icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        "zip"
      ],
      "category": "public.app-category.utilities",
      "darkModeSupport": true
    },
    "dmg": {
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 190,
          "type": "file"
        },
        {
          "x": 410,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "icon": "icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "lxfight <1686540385@qq.com>"
    },
    "snap": {
      "confinement": "strict",
      "grade": "stable"
    }
  }
}
